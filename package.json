{
  "name": "callception",
  "version": "1.0.0",
  "description": "AI destekli çağrı yönetimi, randevu takibi ve müşteri hizmetleri otomasyonu",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dmrcnylmz/smartflowcrm.git"
  },
  "keywords": [
    "crm",
    "ai",
    "customer-service",
    "nextjs",
    "firebase",
    "workflow-automation"
  ],
  "scripts": {
    "dev": "rm -f .next/dev/lock 2>/dev/null; PORT=3002 next dev",
    "dev:3000": "rm -f .next/dev/lock 2>/dev/null; PORT=3000 next dev",
    "dev:3001": "rm -f .next/dev/lock 2>/dev/null; PORT=3001 next dev",
    "dev:3002": "rm -f .next/dev/lock 2>/dev/null; PORT=3002 next dev",
    "dev:clean": "rm -rf .next && PORT=3002 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "setup:firestore": "node scripts/setupFirestore.mjs",
    "seed": "tsx scripts/seed-data.ts",
    "remotion:studio": "npx remotion studio remotion/index.ts",
    "remotion:render": "npx remotion render remotion/index.ts product-demo out/product-demo.mp4",
    "remotion:render:pricing": "npx remotion render remotion/index.ts pricing-overview out/pricing-overview.mp4",
    "remotion:render:en": "npx remotion render remotion/index.ts product-demo-en out/product-demo-en.mp4",
    "remotion:render:pricing:en": "npx remotion render remotion/index.ts pricing-overview-en out/pricing-overview-en.mp4",
    "remotion:render:en:mobile": "npx remotion render remotion/index.ts product-demo-en-mobile out/product-demo-en-mobile.mp4",
    "remotion:render:all": "npm run remotion:render && npm run remotion:render:pricing && npm run remotion:render:en && npm run remotion:render:pricing:en && npm run remotion:render:en:mobile"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@deepgram/sdk": "^4.11.3",
    "@floating-ui/react-dom": "^2.1.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@remotion/bundler": "^4.0.432",
    "@remotion/cli": "^4.0.432",
    "@remotion/media-parser": "^4.0.432",
    "@remotion/player": "^4.0.432",
    "@remotion/renderer": "^4.0.432",
    "@remotion/studio": "^4.0.432",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.1.0",
    "firebase-admin": "^13.6.1",
    "fraction.js": "^5.3.4",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.552.0",
    "next": "^15.5.12",
    "next-intl": "^4.8.3",
    "openai": "^6.21.0",
    "pdf-parse": "^2.4.5",
    "picomatch": "^4.0.3",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.0",
    "recharts": "^2.15.0",
    "remotion": "^4.0.432",
    "resend": "^6.9.3",
    "styled-jsx": "^5.1.7",
    "sucrase": "^3.35.1",
    "swagger-ui-react": "^5.32.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.19",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "jsdom": "^28.0.0",
    "tsx": "^4.7.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
