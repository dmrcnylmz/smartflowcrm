# ===========================================
# SmartFlow CRM - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.
# For Vercel: add these in Project Settings > Environment Variables

# --- Firebase (Client-side) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin SDK (Server-side) ---
# Option 1: Inline JSON (for Vercel - paste raw JSON or base64)
FIREBASE_SERVICE_ACCOUNT_KEY=
# Option 2: File path (for local development only)
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./service-account-key.json

# --- AI Providers ---
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=

# --- Ollama (Local AI - Optional) ---
# Used in lib/ai/ollama.ts (reads OLLAMA_URL) and app/api/ai/status/route.ts (reads OLLAMA_BASE_URL)
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# --- Twilio (Voice Calls) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+90...
TWILIO_CONVERSATION_RELAY_URL=
TWILIO_STATUS_CALLBACK_URL=

# --- Resend (Transactional Email) ---
RESEND_API_KEY=re_...
EMAIL_FROM=SmartFlow CRM <noreply@yourdomain.com>
CRON_SECRET=your-secret-for-cron-jobs

# --- iyzico Payment (Turkish payment gateway) ---
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# --- n8n Automation ---
N8N_WEBHOOK_URL=https://YOUR_POD-5678.proxy.runpod.net/webhook
N8N_API_KEY=
# Fallback for PERSONAPLEX_CONTEXT_URL in lib/n8n/client.ts
CONTEXT_API_URL=http://localhost:8999

# --- RunPod (GPU Infrastructure) ---
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# --- Personaplex / RunPod (Voice AI GPU Server) ---
PERSONAPLEX_URL=https://YOUR_POD-8998.proxy.runpod.net
PERSONAPLEX_CONTEXT_URL=https://YOUR_POD-8999.proxy.runpod.net
NEXT_PUBLIC_PERSONAPLEX_URL=https://YOUR_POD-8998.proxy.runpod.net
NEXT_PUBLIC_PERSONAPLEX_CONTEXT_URL=https://YOUR_POD-8999.proxy.runpod.net
PERSONAPLEX_MOCK_MODE=false

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Monitoring (Optional) ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
