# ============================================
# Callception — Hetzner VPS Environment Variables
# ============================================
# Copy to .env and fill in values before running docker compose up

# Domain
DOMAIN=callception.com

# ---- Kokoro TTS ----
# Basic Auth for TTS API (format: user:password)
# Generate: openssl rand -hex 16
KOKORO_API_AUTH=kokoro:CHANGE_THIS_PASSWORD

# ---- n8n Workflow Automation ----
N8N_USER=admin
# Generate: openssl rand -hex 24
N8N_PASSWORD=CHANGE_THIS_PASSWORD

# ---- Context API / Personaplex ----
# Shared API key for Context API authentication
# Generate: openssl rand -hex 32
PERSONAPLEX_API_KEY=CHANGE_THIS_API_KEY

# Context entry TTL in seconds (default: 30 minutes)
CONTEXT_TTL_SEC=1800
